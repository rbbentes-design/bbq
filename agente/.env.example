# ── Ambiente ──────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ── Workspace externo (fora do repositório git) ────────────────────────────────
# Aponte para um diretório fora do repo. Os subdirs são criados automaticamente.
# Exemplo Linux/macOS: /home/user/agente-workspace
# Exemplo Windows:     C:\Users\user\agente-workspace
WORKSPACE_DIR=/absolute/path/to/agente-workspace

# Os caminhos abaixo são derivados de WORKSPACE_DIR por padrão.
# Descomente e sobrescreva apenas se precisar de localização diferente.
# RAW_DIR=${WORKSPACE_DIR}/raw
# NORMALIZED_DIR=${WORKSPACE_DIR}/normalized
# BUNDLES_DIR=${WORKSPACE_DIR}/bundles
# LOGS_DIR=${WORKSPACE_DIR}/logs
# DEBUG_DIR=${WORKSPACE_DIR}/debug
# STATE_DIR=${WORKSPACE_DIR}/state
# SQLITE_PATH=${WORKSPACE_DIR}/agente.db

# ── Playwright ────────────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=false
AUTH_TIMEOUT_MS=120000
DEBUG_AUTH=false

# ── Chrome Profile (para reutilizar sessao ja autenticada) ─────────────────────
# Windows default: C:\Users\<user>\AppData\Local\Google\Chrome\User Data
# O perfil "Default" e o perfil principal do usuario.
CHROME_USER_DATA_DIR=C:\Users\rafael bentes\AppData\Local\Google\Chrome\User Data
CHROME_PROFILE=Default

# ── ZeroHedge ─────────────────────────────────────────────────────────────────
ZEROHEDGE_BASE_URL=https://www.zerohedge.com
ZEROHEDGE_MARKET_EAR_URL=https://www.zerohedge.com/the-market-ear
# STATE_DIR/zerohedge/state.json  (calculado automaticamente via paths.py)
# ZEROHEDGE_STATE_PATH=
# ZEROHEDGE_PROFILE_DIR=

# ── X ─────────────────────────────────────────────────────────────────────────
# X_PROVIDER_MODE: browser | api
X_PROVIDER_MODE=browser
X_TIMELINE_LIMIT=50
# STATE_DIR/x/state.json  (calculado automaticamente via paths.py)
# X_STATE_PATH=
# X_PROFILE_DIR=

# ── Storage ───────────────────────────────────────────────────────────────────
ENABLE_SQLITE=false
# SQLITE_PATH=  (calculado automaticamente via paths.py se ENABLE_SQLITE=true)
